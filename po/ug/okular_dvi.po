#: dviexport.cpp:129
#, kde-format
msgid ""
"<qt>This DVI file refers to external graphic files which are not in "
"PostScript format, and cannot be handled by the <em>dvips</em> program that "
"Okular uses internally to print or to export to PostScript. The "
"functionality that you require is therefore unavailable in this version of "
"Okular.</qt>"
msgstr ""
"<qt>بۇ DVI ھۆججەت غەيرى PostScript پىچىمىدىكى سىرتقى گىرافىكنى نەقىل ئالغان، "
"بۇ نەشرىدىكى Okular مەزكۇر پىچىمنى قوللىمايدۇ، چۈنكى Okular ئىچكى قىسىمدا "
"بېسىش ياكى PostScript پىچىمىقا چىقىرىشقا  ئىشلىتىدىغان <em>dvips</em> "
"پىروگراممىسى مەزكۇر پىچىمنى بىر تەرەپ قىلالمايدۇ.</qt>"

#: dviexport.cpp:137
#, kde-format
msgid ""
"<qt><p>Okular could not locate the program <em>dvips</em> on your computer. "
"That program is essential for the export function to work.</p><p>Hint to the "
"perplexed system administrator: Okular uses the PATH environment variable "
"when looking for programs.</p></qt>"
msgstr ""
"<qt><p>Okular كومپيۇتېرىڭىزدىن <em>dvips</em> نى تاپالمىدى، بۇ پىروگرامما "
"چىقىرىش ئىقتىدارىنىڭ ئىشلىشى ئۈچۈن زۆرۈر.</p><p>بولۇپمۇ سىستېما باشقۇرغۇچىغا "
"تەييارلانغان دوستانە ئەسكەرتىش: Okular پىروگراممىسى PATH مۇھىم ئۆزگەرگۈچىسى "
"ئارقىلىق پىروگراممىنى ئىزدەيدۇ.</p></qt>"

#: dviexport.cpp:231
#, kde-format
msgid ""
"<qt>The external program 'dvips', which was used to export the file, "
"reported an error. You might wish to look at the <strong>document info "
"dialog</strong> which you will find in the File-Menu for a precise error "
"report.</qt>"
msgstr ""
"<qt>ھۆججەت چىقىرىشقا ئىشلىتىدىغان سىرتقى پىروگرامما «dvips» بىر خاتالىقنى "
"مەلۇم قىلدى. تىزىملىك بالداقتىكى ھۆججەت تىزىملىكىدىن <strong>پۈتۈك ئۇچۇرى "
"سۆزلەشكۈ</strong> نى ئېچىپ، تەپسىلىي خاتالىق دوكلاتىنى كۆرەلەيسىز.</qt>"

#: dviFile.cpp:91
#, kde-format
msgid "The DVI file does not start with the preamble."
msgstr "DVI ھۆججەت بېشىدا ئالدىن ماس قەدەملىك كودى يوق."

#: dviFile.cpp:97
#, kde-format
msgid ""
"The DVI file contains the wrong version of DVI output for this program. "
"Hint: If you use the typesetting system Omega, you have to use a special "
"program, such as oxdvi."
msgstr ""
"بۇ DVI ھۆججەت مەزكۇر پىروگراممىغا نىسبەتەن خاتا نەشرىدىكى DVI چىقىرىش نەشرى "
"بار. ئەسكەرتىش: ئەگەر Omega بەتچىلىك سىستېمىسىنى ئىشلىتىۋاتقان بولسىڭىز، بۇ "
"پۈتۈكنى oxdvi غا ئوخشاش ئالاھىدە پىروگراممىدا ئېچىشىڭىز كېرەك."

#: dviFile.cpp:134
#, kde-format
msgid ""
"The DVI file is badly corrupted. Okular was not able to find the postamble."
msgstr ""
"بۇ DVI ھۆججەت ئېغىر دەرىجىدە بۇزۇلغان. Okular ئۇنىڭ ئاخىرى يەنى ئارقا ماس "
"كېلىش كودىنى تاپالمىدى."

#: dviFile.cpp:148
#, kde-format
msgid "The postamble does not begin with the POST command."
msgstr "ئارقا ماس كېلىش كودى POST بۇيرۇقى بىلەن باشلانمىغان."

#: dviFile.cpp:202
#, kde-format
msgid "The postamble contained a command other than FNTDEF."
msgstr "ئارقا ماس كېلىش كودى FNTDEF بولمىغان بۇيرۇقىنى ئۆز ئىچىگە ئالغان."

#: dviFile.cpp:240
#, kde-format
msgid "The page %1 does not start with the BOP command."
msgstr "‎%1-بەت‏ BOP بۇيرۇقى بىلەن باشلانمىغان ."

#: dviFile.cpp:354
#, kde-format
msgid ""
"<qt><p>The external program <strong>pdf2ps</strong> could not be started. As "
"a result, the PDF-file %1 could not be converted to PostScript. Some graphic "
"elements in your document will therefore not be displayed.</p><p><b>Possible "
"reason:</b> The program <strong>pdf2ps</strong> may not be installed on your "
"system, or cannot be found in the current search path.</p><p><b>What you can "
"do:</b> The program <strong>pdf2ps</strong> is normally contained in "
"distributions of the ghostscript PostScript interpreter system. If "
"ghostscript is not installed on your system, you could install it now. If "
"you are sure that ghostscript is installed, try to use <strong>pdf2ps</"
"strong> from the command line to check if it really works.</p><p><em>PATH:</"
"em> %2</p></qt>"
msgstr ""
"<qt><p>سىرتقى پىروگرامما <strong>pdf2ps</strong> نى قوزغىتالمايدۇ. بۇ PDF "
"ھۆججەت %1 نى PostScript پىچىمىغا ئايلاندۇرالمايدۇ. پۈتۈكتىكى بەزى گىرافىك "
"ئېلېمېنتنى كۆرسەتمەيدۇ.</p><p><b>مۇمكىن بولغان سەۋەب:</b>بۇ سىستېمىغا "
"<strong>pdf2ps</strong> ئورنىتىلمىغان بولۇشى مۇمكىن ياكى نۆۋەتتىكى "
"پىروگرامما ئىزدەش يولىدا ئۇنى تاپالمىدى.</p><p><b>ھەل قىلىش ئۇسۇلى:</"
"b><strong>pdf2ps</strong> پىروگراممىسى ghostscript PostScript كود يەشكۈچ "
"بىلەن بىللە تارقىتىلىدۇ. ئەگەر سىستېمىڭىزغا ghostscript ئورنىتىلمىغان بولسا، "
"ھازىر ئۇنى ئورنىتىڭ. ئەگەر سىستېمىڭىزغا ghostscript ئورنىتىلغان بولسا، "
"بۇيرۇق قۇرىدا <strong>pdf2ps</strong> پىروگراممىنى ئىجرا قىلىشنى سىناپ، "
"ئادەتتىكىدەك ئىشلەمدۇ يوق تەكشۈرۈڭ.</p><p><em>PATH:</em> %2</p></qt>"

#: dviFile.cpp:415
#, kde-format
msgid ""
"<qt><p>The PDF-file %1 could not be converted to PostScript. Some graphic "
"elements in your document will therefore not be displayed.</p><p><b>Possible "
"reason:</b> The file %1 might be broken, or might not be a PDF-file at all. "
"This is the output of the <strong>pdf2ps</strong> program that Okular used:</"
"p><p><strong>%2</strong></p></qt>"
msgstr ""
"<qt><p>بۇ PDF ھۆججەت %1 نى PostScript پىچىمىغا ئايلاندۇرالمايدۇ. پۈتۈكتىكى "
"بەزى گىرافىك ئېلېمېنت كۆرسىتىلمەيدۇ.</p><p><b>مۇمكىن بولغان سەۋەب:</b>%1 "
"ھۆججەت بۇزۇلغان بولۇشى مۇمكىن ياكى PDF ھۆججەت بولماسلىقىمۇ مۇمكىن. بۇ Okular "
"نىڭ <strong>pdf2ps</strong> نى چاقىرغاندىكى چىقىرىشى:</p><p><strong>%2</"
"strong></p></qt>"

#: dviRenderer.cpp:203 dviRenderer.cpp:435
#, kde-format
msgid "File corruption. %1"
msgstr "ھۆججەت بۇزۇلغان. %1"

#: dviRenderer.cpp:326
#, kde-format
msgid "Not all PostScript files could be embedded into your document. %1"
msgstr "ھەممە PostScript ھۆججەتنى پۈتۈككە سىڭدۈرگىلى بولۇشى ناتايىن. %1"

#: dviRenderer.cpp:329
#, kde-format
msgid "All external PostScript files were embedded into your document."
msgstr "بارلىق سىرتقى PostScript ھۆججەت پۈتۈكىڭىزگە سىڭدۈرۈلگەن."

#: dviRenderer.cpp:419
#, kde-format
msgid "The specified file '%1' does not exist."
msgstr "كۆرستىلگەن «%1» ھۆججەت مەۋجۇت ئەمەس."

#: dviRenderer.cpp:565
#, kde-format
msgid ""
"You have asked Okular to locate the place in the DVI file which corresponds "
"to line %1 in the TeX-file %2. It seems, however, that the DVI file does not "
"contain the necessary source file information. "
msgstr ""
"سىز Okular دىن DVI ھۆججەتتىكى TeX ھۆججەت %2 نىڭ %1-قۇرىغا ئورۇن بەلگىلەشنى "
"ئىلتىماس قىلدىڭىز. بىراق، مەزكۇر DVI ھۆججەتتە زۆرۈر بولغان مەنبە ھۆججەت "
"ئۇچۇرى كەم. "

#: dviRenderer.cpp:604
#, kde-format
msgid ""
"Okular was not able to locate the place in the DVI file which corresponds to "
"line %1 in the TeX-file %2."
msgstr ""
"Okular بۇ DVI ھۆججەتتىكى TeX ھۆججەت %2 نىڭ %1-قۇرىغا ئورۇن بەلگىلىيەلمىدى."

#: dviRenderer_draw.cpp:239
#, kde-format
msgid "The DVI code set a character of an unknown font."
msgstr "بۇ DVI كودى يوچۇن بىر خەت نۇسخىسىدىكى ھەرپنى تەڭشىگەن."

#: dviRenderer_draw.cpp:266 dviRenderer_prescan.cpp:667
#, kde-format
msgid "The DVI code referred to font #%1, which was not previously defined."
msgstr "DVI كودى #%1 خەت نۇسخىسىنى بەلگىلىگەن‎‏، لېكىن ئىلگىرى ئېنىقلانمىغان."

#: dviRenderer_draw.cpp:349
#, kde-format
msgid "The stack was not empty when the EOP command was encountered."
msgstr "EOP بۇيرۇقىغا يولۇققاندا، دەستە بوش ئەمەس."

#: dviRenderer_draw.cpp:361
#, kde-format
msgid "The stack was empty when a POP command was encountered."
msgstr "POP بۇيرۇقىغا يولۇققاندا، دەستە بوش ئەمەس."

#: dviRenderer_draw.cpp:485 dviRenderer_draw.cpp:494
#, kde-format
msgid "The DVI code referred to a font which was not previously defined."
msgstr "DVI كودى ئىشلەتكەن خەت نۇسخىسى ئالدىن ئېنىقلانمىغان."

#: dviRenderer_draw.cpp:535
#, kde-format
msgid "An illegal command was encountered."
msgstr "خاتا بۇيرۇققا يولۇقتى."

#: dviRenderer_draw.cpp:540
#, kde-format
msgid "The unknown op-code %1 was encountered."
msgstr "نامەلۇم  op-كودى %1 غا يولۇقتى."

#: dviRenderer_prescan.cpp:87
#, kde-format
msgid "Embedding %1"
msgstr "%1 نى سىڭدۈرۈۋاتىدۇ"

#: dviRenderer_prescan.cpp:105
#, kde-format
msgid ""
"Page %1: The PDF file <strong>%2</strong> could not be converted to "
"PostScript.<br>"
msgstr ""
"%1-بەت: بۇ PDF ھۆججەت <strong>%2</strong> نى PostScript قا ئايلاندۇرالمايدۇ."
"<br>"

#: dviRenderer_prescan.cpp:107
#, kde-format
msgid ""
"Page %1: The PostScript file <strong>%2</strong> could not be found.<br>"
msgstr "%1-بەت: بۇ PostScript ھۆججەت <strong>%2</strong> نى تاپالمىدى.<br>"

#: dviRenderer_prescan.cpp:261
#, kde-format
msgid "The papersize data '%1' could not be parsed."
msgstr "قەغەز چوڭلۇقى سانلىق مەلۇماتى «%1» نى يېشەلمىدى."

#: fontpool.cpp:194
#, kde-format
msgid ""
"<qt><p>Okular was not able to locate all the font files which are necessary "
"to display the current DVI file. Your document might be unreadable.</"
"p><p><small><b>PATH:</b> %1</small></p><p><small>%2</small></p></qt>"
msgstr ""
"<qt><p>Okular نۆۋەتتىكى DVI ھۆججەتنى كۆرسىتىشكە زۆرۈر بولغان ھەممە خەت نۇسخا "
"ھۆججىتىنى تاپالمىدى. بۇ پۈتۈكنى ئوقۇغۇدەك كۆرسىتەلمەسلىكى مۇمكىن.</"
"p><p><small><b>PATH:</b> %1</small></p><p><small>%2</small></p></qt>"

#: fontpool.cpp:269
#, kde-format
msgid ""
"<qt><p>There were problems running <em>kpsewhich</em>. As a result, some "
"font files could not be located, and your document might be unreadable.<br/"
">Possible reason: the <em>kpsewhich</em> program is perhaps not installed on "
"your system, or it cannot be found in the current search path.</"
"p><p><small><b>PATH:</b> %1</small></p><p><small>%2</small></p></qt>"
msgstr ""
"<qt><p><em>kpsewhich</em> نى ئىجرا قىلىۋاتقاندا مەسىلە كۆرۈلدى. بەزى خەت "
"نۇسخىسىنىڭ ئورنىنى بەلگىلىيەلمىدى، پۈتۈكنى ئوقۇغىلى بولماسلىقى مۇمكىن.<br/"
">مۇمكىن بولغان سەۋەب: مەزكۇر سىستېمىغا <em>kpsewhich</em> پىروگراممىسى "
"ئورنىتىلمىغان بولۇشى مۇمكىن ياكى ئۇنى نۆۋەتتىكى ئىزدەش يولىدىن تاپالمىدى.</"
"p><p><small><b>PATH:</b> %1</small></p><p><small>%2</small></p></qt>"

#: fontpool.cpp:290
#, kde-format
msgid ""
"<qt>The font generation by <em>kpsewhich</em> was aborted (exit code %1, "
"error %2). As a result, some font files could not be located, and your "
"document might be unreadable.</qt>"
msgstr ""
"<qt><em>kpsewhich</em> تەمىنلىگەن خەت نۇسخا ھاسىللاش مەشغۇلاتى توختىتىلدى "
"(چېكىنىش كودى: %1، خاتالىق %2). شۇڭا بەزى خەت نۇسخىلىرىنىڭ ئورنىنى "
"بەلگىلىيەلمىدى، پۈتۈكنى ئوقۇغىلى بولماسلىقى مۇمكىن.</qt>"

#: fontpool.cpp:467
#, kde-format
msgid "Currently generating %1 at %2 dpi…"
msgstr "نۆۋەتتە %2 dpi ئېنىقلىقتىكى %1 نى شەكىللەندۈرۈۋاتىدۇ…"

#: generator_dvi.cpp:293
#, kde-format
msgid "Generator/Date"
msgstr "ھاسىللىغۇچ/چېسلا"

#: generator_dvi.cpp:382
#, kde-format
msgid "Font file not found"
msgstr "خەت نۇسخا ھۆججىتى تېپىلمىدى"

#: psgs.cpp:286
#, kde-format
msgid ""
"The version of Ghostview that is installed on this computer does not contain "
"any of the Ghostview device drivers that are known to Okular. PostScript "
"support has therefore been turned off in Okular."
msgstr ""
"بۇ كومپيۇتېرغا ئورنىتىلغان Ghostview نەشرىدە Okular قوللايدىغان ھېچقانداق "
"Ghostview ئۈسكۈنە قوزغاتقۇ ئورنىتىلمىغان. شۇ سەۋەبتىن Okular دا PostScript "
"قوللاش تاقالدى."

#: special.cpp:36
#, kde-format
msgid "That makes 25 errors. Further error messages will not be printed."
msgstr ""
"25 خاتالىق يۈز بەردى. پىروگرامما تېخىمۇ كۆپ خاتالىق ئۇچۇرىنى بېسىپ "
"چىقارمايدۇ."

#: special.cpp:232
#, kde-format
msgid ""
"Error in DVIfile '%1', page %2. Color pop command issued when the color "
"stack is empty."
msgstr ""
"«%1» DVI ھۆججەتنىڭ %2-بېتىدە خاتالىق بار. رەڭ دەستىسى بوش بولغاندا رەڭ "
"قاڭقىش خاتالىقى كۆرۈلىدۇ."

#: special.cpp:318
#, kde-format
msgid ""
"Malformed parameter in the epsf special command.\n"
"Expected a float to follow %1 in %2"
msgstr ""
"epsf ئالاھىدە بۇيرۇقىنىڭ ئۆزگەرگۈچىسىدە خاتالىق بار.\n"
"%2 دىكى %1 دىن كېيىن كەسىر سان كېلىشى كېرەك"

#: special.cpp:446
#, kde-format
msgid ""
"File not found: \n"
" %1"
msgstr ""
"ھۆججەت تېپىلمىدى:\n"
"%1"

#: special.cpp:695
#, kde-format
msgid ""
"Error in DVIfile '%1', page %2. Could not interpret angle in text rotation "
"special."
msgstr ""
"«%1» DVI ھۆججەتنىڭ %2-بېتىدە خاتالىق بار. تېكىستنى ئايلاندۇرىدىغان ئالاھىدە "
"بۇيرۇقنىڭ بۇلۇڭىنى يېشەلمىدى."

#: special.cpp:714
#, kde-format
msgid "The special command '%1' is not implemented."
msgstr "ئالاھىدە بۇيرۇق «%1» نى ئەمەلىيلەشتۈرەلمىدى."

#: TeXFont_PFB.cpp:43
#, kde-format
msgid ""
"The font file %1 could be opened and read, but its font format is "
"unsupported."
msgstr ""
"خەت نۇسخا ھۆججەت %1 نى ئېچىپ ۋە ئوقۇيالايدۇ ئەمما خەت نۇسخا پىچىمىنى "
"قوللىمايدۇ."

#: TeXFont_PFB.cpp:48
#, kde-format
msgid "The font file %1 is broken, or it could not be opened or read."
msgstr "خەت نۇسخا ھۆججەت %1 بۇزۇلغان ياكى ئېچىپ ياكى ئوقۇيالمايدۇ."

#: TeXFont_PFB.cpp:167
#, kde-format
msgid ""
"FreeType reported an error when setting the character size for font file %1."
msgstr ""
"FreeType خەت نۇسخا ھۆججىتى %1 دا خەت چوڭلۇقىنى تەڭشەۋاتقاندا بىر خاتالىق "
"مەلۇم قىلىندى."

#: TeXFont_PFB.cpp:185
#, kde-format
msgid "FreeType is unable to load glyph #%1 from font file %2."
msgstr "FreeType خەت نۇسخا ھۆججىتى %2 دىكى #%1 خەت شەكلىنى يۈكلىيەلمىدى."

#: TeXFont_PFB.cpp:198
#, kde-format
msgid "FreeType is unable to render glyph #%1 from font file %2."
msgstr "FreeType خەت نۇسخا ھۆججىتى %2 دىكى #%1 خەت شەكلىنى ھاسىللىيالمىدى."

#: TeXFont_PFB.cpp:212
#, kde-format
msgid "Glyph #%1 is empty."
msgstr "#%1 خەت شەكلى بوش."

#: TeXFont_PFB.cpp:214
#, kde-format
msgid "Glyph #%1 from font file %2 is empty."
msgstr "خەت نۇسخا ھۆججىتى %2 دىكى #%1 خەت شەكلى بوش."

#: TeXFont_PFB.cpp:279
#, kde-format
msgid "FreeType is unable to load metric for glyph #%1 from font file %2."
msgstr ""
"FreeType خەت نۇسخا ھۆججىتى %2 دىكى #%1 خەت شەكلى ئۆلچىمىنى يۈكلىيەلمىدى."

#: TeXFont_PK.cpp:69
#, kde-format
msgid "Cannot open font file %1."
msgstr "%1 خەت نۇسخا ھۆججەتنى ئاچالمىدى."

#: TeXFont_PK.cpp:116
#, kde-format
msgid "TexFont_PK::operator[]: Character %1 not defined in font %2"
msgstr "TexFont_PK::operator[]: ھەرپ %1 خەت نۇسخىسى %2 دا ئېنىقلانمىغان"

#: TeXFont_PK.cpp:419
#, kde-format
msgid "Unexpected %1 in PK file %2"
msgstr "PK ھۆججەت %2 دا كۈتۈلمىگەن %1 كۆرۈلدى"

#: TeXFont_PK.cpp:485
#, kde-format
msgid "The character %1 is too large in file %2"
